# Database (Neon)
DATABASE_URL=postgresql://user:password@host:5432/neondb

# App URL
NEXT_PUBLIC_URL=http://localhost:3000

# Billplz (Payment Gateway)
BILLPLZ_API_URL=https://www.billplz.com/api/v3
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_SIGNATURE_KEY=

# Cloudinary (Image Upload)
# Required for both server-stream uploads and signed browser uploads.
# The same CLOUDINARY_API_SECRET value must be set in BOTH this .env
# (for local dev) and Vercel env vars (for production).
# After pasting, run: npx tsx scripts/verify-sign.ts
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_WEBHOOK_SECRET=

# Brevo (Transactional Email Outbound)
BREVO_API_KEY=
FROM_EMAIL=hello@leish.my
FROM_NAME=Leish

# Inbound email is handled by Cloudflare Email Routing (MX → Cloudflare)
# https://dash.cloudflare.com → Email → Routing
# Routes forward each @leish.my alias to the appropriate Gmail inboxes
# No Brevo Inbound Parse needed

# Google Calendar
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_KEY=

# WhatsApp Notifications
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Cron / Webhook
CRON_SECRET=

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Neon Auth
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=
NEXT_PUBLIC_NEON_AUTH_BASE_URL=

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Meta Pixel / Facebook Pixel (optional)
NEXT_PUBLIC_FB_PIXEL_ID=

# Sentry (Error Monitoring)
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Email Aliases
SUPPORT_EMAIL=support@leish.my
BILLING_EMAIL=billing@leish.my
MARKETING_EMAIL=marketing@leish.my
ADMIN_EMAIL=admin@leish.my
NOTIFICATIONS_EMAIL=notifications@leish.my
INFO_EMAIL=info@leish.my
STUDIO_EMAIL=studio@leish.my
ARTIST_EMAIL=artist@leish.my

# Inbound Email (Cloudflare Email Routing → Gmail)
# Each @leish.my alias forwards directly to a Gmail inbox
# Configured in Cloudflare Dashboard → Email → Routing
CENTRAL_INBOX_EMAIL=leishstudio.main@gmail.com
